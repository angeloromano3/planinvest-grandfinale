spring.application.name=planinvest

# Endereço do banco de dados
# Defina a variável de ambiente DB_URL (ou use o padrão abaixo)
spring.datasource.url=${DB_URL:jdbc:oracle:thin:@SEU_HOST:1521:SEU_SID}
# Usuário do banco de dados - defina a variável de ambiente DB_USERNAME
spring.datasource.username=${DB_USERNAME}
# Senha do banco de dados - defina a variável de ambiente DB_PASSWORD
spring.datasource.password=${DB_PASSWORD}

# Mostrar as instruções SQL executadas no banco de dados
spring.jpa.show-sql=true

# JPA / Hibernate
spring.jpa.hibernate.ddl-auto=none

spring.sql.init.mode=always